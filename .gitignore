# Genomics data - never commit raw sequencing or alignment files
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.bam.bai
*.cram
*.cram.crai
*.sam
*.vcf
*.vcf.gz
*.bcf

# Genome assemblies (large FASTA files)
data/genomes/
reference/*.fasta

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# Environment
.env
environment.yml
miniforge.sh

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temp
*.tmp
*.temp

# Large downloaded data (not committed to git)
# CRyPTIC data: full table (1.4 GB) + extracted cache/supplement files
# Committed as data/cryptic_supplement.tar.gz
data/cryptic/
!data/cryptic_supplement.tar.gz
# Individual PDB files are committed as data/pdbs.tar.gz
data/pdb/**/*.pdb
# Model pickles (regenerated by scripts)
analysis/results/hotspot_model/*.pkl
analysis/results/forecasting/xgboost_model.pkl
analysis/results/forecasting/all_mutations_scored.csv
